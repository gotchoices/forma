source "https://rubygems.org"

# Matches the Jekyll + plugin versions GitHub Pages actually builds with.
# See https://pages.github.com/versions/ for the current set.
gem "github-pages", group: :jekyll_plugins

# Windows/JRuby timezone support (harmless on macOS/Linux).
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
gem "wdm", ">= 0.1.0", platforms: [:mingw, :mswin, :x64_mingw]
